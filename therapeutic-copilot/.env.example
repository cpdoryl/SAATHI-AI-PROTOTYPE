# ─── SAATHI AI — App-level .env.example ──────────────────────────────────────
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── AI Inference ─────────────────────────────────────────────────────────────
# Stage 2 LoRA adapter (QLoRA r=16 on Qwen2.5-3B-Instruct, trained locally)
# Path to deployed adapter directory (set after running 04_deploy_stage2_adapter.py)
STAGE2_LORA_ADAPTER_PATH=C:\saath ai prototype\therapeutic-copilot\server\ml_models\stage2_therapy_model

# Self-hosted llama.cpp on E2E Networks (prod base model serving)
LLAMA_CPP_SERVER_URL=http://localhost:8080

# ─── RAG / Pinecone ───────────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=therapeutic-kb

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite — no setup needed):
DATABASE_URL=sqlite:///./saathi_copilot.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql://saathi:password@localhost:5432/saathi_copilot

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_here

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@your-clinic-domain.com

# ─── Google Calendar ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ─── App Config ───────────────────────────────────────────────────────────────
DEBUG_MODE=true
LOG_LEVEL=DEBUG
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
