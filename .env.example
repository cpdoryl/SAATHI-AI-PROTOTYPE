# ─── SAATHI AI — Root-level .env.example ─────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL (Docker Compose) ─────────────────────────────────────────────
POSTGRES_USER=saathi
POSTGRES_PASSWORD=saathi_dev_password_change_in_prod
POSTGRES_DB=saathi_copilot
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Application ─────────────────────────────────────────────────────────────
APP_PORT=8000
FRONTEND_PORT=5173
